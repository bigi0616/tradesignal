# 포트 (Render 자동 설정)
PORT=3000
NODE_ENV=development

# 공공데이터포털 API 키
# 발급: data.go.kr → 로그인 → 마이페이지 → 일반 인증키
DATA_GO_KR_KEY=여기에_공공데이터포털_API키_입력

# Claude API 키 (인사이트 자동 생성)
# 발급: console.anthropic.com → API Keys
CLAUDE_API_KEY=sk-ant-여기에_클로드_API키_입력

# 관리자 수동 트리거 비밀키 (아무 문자열)
ADMIN_SECRET=my-secret-2026
